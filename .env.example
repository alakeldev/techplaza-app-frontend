# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of the Django REST Framework backend API (no trailing slash).
# Leave blank (or remove this line) to use the live production API.
# Set to http://localhost:8000/api when running the backend locally.
REACT_APP_API_BASE_URL=

# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# API key for the World Weather Application.
# Obtain a free key at https://openweathermap.org/api
REACT_APP_WEATHER_API_KEY=

# ─── EmailJS (Contact Form) ───────────────────────────────────────────────────
# Credentials for sending contact-form messages via EmailJS.
# Sign up and create a service + template at https://www.emailjs.com/
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_USER_ID=
